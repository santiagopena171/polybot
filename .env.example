# ───────────────────────────────────────────────
#  Polymarket Bot — Environment Variables
#  Copy to .env and fill in your values
# ───────────────────────────────────────────────

# ── Polymarket / Polygon wallet ──────────────────
# Private key of the Polygon wallet that holds USDC
POLYGON_PRIVATE_KEY=0xyour_private_key_here

# Derived from the private key — leave blank to auto-derive
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ── OpenAI (probability estimator) ───────────────
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o

# ── News API (newsapi.org) ────────────────────────
NEWS_API_KEY=your_newsapi_key_here

# ── Bot behavior ─────────────────────────────────
# Minimum edge required before placing a trade (e.g. 0.05 = 5 pp)
MIN_EDGE=0.07

# Maximum fraction of bankroll to risk per trade (Kelly fraction)
MAX_KELLY_FRACTION=0.25

# Maximum single trade size in USDC
MAX_TRADE_SIZE_USDC=50

# How many top markets to scan each cycle
MARKETS_TO_SCAN=30

# Seconds between full scan cycles
SCAN_INTERVAL_SECONDS=300

# Dry-run: set to "true" to log trades without executing them
DRY_RUN=true
# Single-cycle mode: "true" para GitHub Actions (corre un ciclo y termina)
# "false" para servidor/VPS (loop continuo)
SINGLE_CYCLE=false
# ── Logging ──────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
